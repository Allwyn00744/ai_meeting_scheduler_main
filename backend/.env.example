# Copy this file to .env and fill in real values. Never commit the
# real .env file.
#
# Running via Docker Compose (see ../docker-compose.yml)? DATABASE_URL
# and REDIS_URL below are overridden there to point at the "postgres"
# and "redis" service hostnames - the values here are only used for
# non-Docker local dev (`python run.py`).

# --- Database ---
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/dbname

# Set to true only for local debugging - logs every SQL statement,
# including bound parameter values. Leave false in shared/prod envs.
SQLALCHEMY_ECHO=false

# --- Email (SMTP) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your-smtp-username
EMAIL_PASSWORD=your-smtp-app-password
EMAIL_FROM=your-from-address@example.com

# Set true only if EMAIL_PORT is an implicit-SSL port (typically 465).
# Leave false for STARTTLS ports (typically 587, e.g. Gmail SMTP).
EMAIL_USE_SSL=false
EMAIL_TIMEOUT_SECONDS=10

# --- Google OAuth / Calendar ---
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/google/callback

# Frontend origin the OAuth callback redirects back to after it
# finishes (success or error). No trailing slash.
FRONTEND_URL=http://localhost:5173

# --- Microsoft OAuth / Outlook Calendar + Microsoft Teams (optional) ---
# Optional: /outlook endpoints return 503 when absent or blank.
# Register an app at https://portal.azure.com (Azure AD App
# registrations) to obtain these. Microsoft Teams Integration V1
# reuses this same Outlook connection - there is no separate Teams
# app registration or OAuth flow.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:8000/outlook/callback

# "common" allows both work/school and personal Microsoft accounts.
MICROSOFT_TENANT_ID=common
# OnlineMeetings.ReadWrite is required for Microsoft Teams Integration
# V1 (setting isOnlineMeeting/onlineMeetingProvider on Outlook events).
# Users who connected Outlook before this scope was added need to
# reconnect once to get a token that includes it - /teams/sync returns
# a 400 asking them to do so rather than failing silently.
MICROSOFT_SCOPES=https://graph.microsoft.com/Calendars.ReadWrite https://graph.microsoft.com/OnlineMeetings.ReadWrite offline_access

# --- Zoom OAuth / Zoom Meetings (optional) ---
# Optional: /zoom endpoints return 503 when absent or blank. Register
# a User-managed OAuth app (Authorization Code Grant) at
# https://marketplace.zoom.us/develop/create to obtain these.
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_REDIRECT_URI=http://localhost:8000/zoom/callback
ZOOM_SCOPES=meeting:write

# --- Slack OAuth / Slack Notifications (optional) ---
# Optional: /slack endpoints return 503 when absent or blank. Create a
# Slack app (OAuth & Permissions -> Bot Token Scopes: chat:write) at
# https://api.slack.com/apps to obtain these. Slack Notifications V1
# sends a direct message to the Slack user who connected the
# workspace - there is no channel selection.
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:8000/slack/callback
SLACK_SCOPES=chat:write

# --- WhatsApp Cloud API / WhatsApp Notifications (optional) ---
# Optional: /whatsapp send/test endpoints return 503 when absent or
# blank. Create a Meta app with the WhatsApp product added at
# https://developers.facebook.com/apps to obtain these. Each user's
# own recipient phone number is stored separately in whatsapp_settings,
# not here.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v23.0

# --- Web Push / Push Notifications (optional) ---
# Optional: PushClient.send_notification returns False (best-effort,
# never raises) when absent or blank. Generate a VAPID key pair with
# `vapid --gen` (py-vapid, pulled in by pywebpush) to obtain these.
# Each user's own browser subscriptions are stored separately in
# push_subscriptions, not here.
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIM_EMAIL=admin@example.com

# --- JWT ---
# Required, no default. Generate with: openssl rand -hex 32
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- CORS ---
# Comma-separated list of allowed frontend origins. Never use "*".
CORS_ORIGINS=http://localhost:3000

# --- Pagination defaults ---
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=200

# --- Redis cache (optional) ---
# Redis is optional infrastructure. Leave REDIS_URL blank to run
# without a cache - every read falls back to PostgreSQL and startup
# is unaffected. Example: redis://localhost:6379/0
REDIS_URL=
REDIS_SOCKET_TIMEOUT_SECONDS=2.0
REDIS_CONNECT_TIMEOUT_SECONDS=2.0
