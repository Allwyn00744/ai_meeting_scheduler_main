# Copy this file to .env (repo root) and fill in real values. Never
# commit the real .env file. These variables are used by
# docker-compose.yml for container/network configuration; they are
# separate from backend/.env and frontend/.env, which still hold the
# application secrets (SMTP, Google OAuth, JWT secret, Gemini key).

# --- PostgreSQL (compose-managed container) ---
POSTGRES_USER=scheduler_user
POSTGRES_PASSWORD=change-me
POSTGRES_DB=scheduler_db
POSTGRES_PORT=5432

# --- Host port mappings ---
BACKEND_PORT=8000
FRONTEND_PORT=5173

# --- Backend CORS / OAuth redirect target ---
# Must match FRONTEND_PORT above (browser-facing frontend origin).
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
FRONTEND_URL=http://localhost:5173

# --- Frontend build-time backend URL ---
# Baked into the static JS bundle at image build time (Vite inlines
# env vars at build time, not runtime) - must be a browser-reachable
# URL, not a Docker-internal service hostname. Must match BACKEND_PORT.
VITE_API_URL=http://localhost:8000
